generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  SHIPPING
  COMPLETED
  CANCELLED
}

model Product {
  id               String      @id
  name             String
  description      String
  detailIntro      String      @map("detail_intro")
  price            Int
  originalPrice    Int?        @map("original_price")
  weightRange      String      @map("weight_range")
  tempLayer        String      @map("temp_layer")
  traceOrigin      String      @map("trace_origin")
  traceHarvestDate String?     @map("trace_harvest_date")
  traceCertUrl     String      @map("trace_cert_url")
  tags             String[]
  image            String
  scaleImage       String      @map("scale_image")
  gallery          String[]
  category         String
  sku              String      @unique
  stockStatus      String      @map("stock_status")
  promoLabel       String?     @map("promo_label")
  specItems        String[]    @map("spec_items")
  shippingInfo     String      @map("shipping_info")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  orderItems       OrderItem[]

  @@map("products")
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique @map("order_number")
  clerkUserId    String?     @map("clerk_user_id")
  status         OrderStatus @default(PENDING_PAYMENT)
  totalAmount    Int         @map("total_amount")
  recipientName  String      @map("recipient_name")
  phone          String
  email          String
  address        String
  city           String
  postalCode     String      @map("postal_code")
  note           String?
  paymentMethod        String      @map("payment_method")
  ecpayMerchantTradeNo String?     @unique @map("ecpay_merchant_trade_no")
  ecpayTradeNo         String?     @map("ecpay_trade_no")
  paidAt         DateTime?   @map("paid_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  items          OrderItem[]

  @@index([clerkUserId])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  quantity    Int
  unitPrice   Int     @map("unit_price")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  title          String
  discountText   String       @map("discount_text")
  minAmount      Int?         @map("min_amount")
  discountAmount Int?         @map("discount_amount")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  userCoupons    UserCoupon[]

  @@map("coupons")
}

model UserCoupon {
  id          String    @id @default(cuid())
  clerkUserId String    @map("clerk_user_id")
  couponId    String    @map("coupon_id")
  usedAt      DateTime? @map("used_at")
  coupon      Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([clerkUserId, couponId])
  @@index([clerkUserId])
  @@map("user_coupons")
}
