# 開發環境
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub Pages 靜態部署（由 CI 自動設定，本地 build:pages 可手動加入）
# GITHUB_PAGES=true
# NEXT_PUBLIC_BASE_PATH=/seefood-shop
# NEXT_PUBLIC_STATIC_EXPORT=true

# 生產環境（部署時覆寫）
# NEXT_PUBLIC_API_BASE_URL=https://your-domain.com
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# 第二階段：資料庫
# DATABASE_URL=postgresql://user:pass@localhost:5432/seafood

# 第二階段：金流
# LINE_PAY_CHANNEL_ID=
# LINE_PAY_CHANNEL_SECRET=

# 第二階段：物流
# LOGISTICS_API_URL=
