# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Neon PostgreSQL（Prisma）
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth（Neon Console → Auth → Configuration）
NEXT_PUBLIC_NEON_AUTH_ENABLED=true
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
# Next.js 需至少 32 字元：openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=your-secret-at-least-32-characters-long
# 選填：seed 時綁定示範優惠券的 Neon Auth User ID
# NEON_AUTH_DEMO_USER_ID=

# 綠界 ECPay（測試環境預設值見文件）
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_ENV=stage

# GitHub Pages 靜態部署（Vercel 部署請勿設定）
# GITHUB_PAGES=true
# NEXT_PUBLIC_BASE_PATH=/seefood-shop
# NEXT_PUBLIC_STATIC_EXPORT=true
